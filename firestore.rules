rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global shared study data sync across devices
    match /app_data/{docId} {
      allow read, write: if true;
    }
    match /user_data/{docId} {
      allow read, write: if true;
    }
    // Users can read/write their own user profile & study data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Public leaderboard or study groups for making friends
    match /public_profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /study_rooms/{roomId} {
      allow read, write: if request.auth != null;
    }
  }
}
